{
  "info": {
    "name": "E-Commerce Marketplace API",
    "description": "Golden-path walkthrough: admin sets up a vendor and category, the vendor lists a product, and a customer registers, browses, carts, and checks out. Run the whole collection top-to-bottom with Collection Runner, or step through requests individually — each request that returns a token or id saves it into a collection variable for the next request to use.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8082/api/v1" },
    { "key": "adminEmail", "value": "admin@marketplace.com" },
    { "key": "adminPassword", "value": "ChangeMe123!" },
    { "key": "vendorEmail", "value": "vendor.demo@marketplace.com" },
    { "key": "vendorPassword", "value": "VendorPass123!" },
    { "key": "customerEmail", "value": "customer.demo@marketplace.com" },
    { "key": "customerPassword", "value": "CustomerPass123!" },
    { "key": "adminToken", "value": "" },
    { "key": "vendorToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "vendorUserId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Admin setup",
      "item": [
        {
          "name": "Login as seeded admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('login succeeded', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('adminToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Register vendor-to-be user",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('registration succeeded', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('vendorUserId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{vendorEmail}}\",\n  \"password\": \"{{vendorPassword}}\",\n  \"fullName\": \"Demo Vendor\",\n  \"phone\": \"+971500000000\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Promote user to VENDOR",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/users/{{vendorUserId}}/promote-to-vendor"
          }
        },
        {
          "name": "Create category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('category created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('categoryId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Electronics\"\n}"
            },
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "2. Vendor lists a product",
      "item": [
        {
          "name": "Login as vendor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('login succeeded', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('vendorToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{vendorEmail}}\",\n  \"password\": \"{{vendorPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Create product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('product created', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('productId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{vendorToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Wireless Mouse\",\n  \"description\": \"Ergonomic wireless mouse\",\n  \"price\": 99.00,\n  \"stockQuantity\": 25,\n  \"sku\": \"WM-DEMO-001\",\n  \"categoryId\": \"{{categoryId}}\"\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        }
      ]
    },
    {
      "name": "3. Customer golden path",
      "item": [
        {
          "name": "Register customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"fullName\": \"Demo Customer\",\n  \"phone\": \"+971500000001\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login as customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('login succeeded', () => pm.response.to.have.status(200));",
                  "pm.collectionVariables.set('customerToken', body.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Browse products (public, no auth)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products?categoryId={{categoryId}}"
          }
        },
        {
          "name": "Add product to cart",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/cart/items"
          }
        },
        {
          "name": "View cart",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/cart"
          }
        },
        {
          "name": "Checkout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('checkout succeeded', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('orderId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": \"123 Sheikh Zayed Road, Dubai, UAE\"\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "View placed order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{customerToken}}" }],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    }
  ]
}
